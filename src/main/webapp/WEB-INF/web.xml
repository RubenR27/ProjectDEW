<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0">
  <display-name>ProjectDEW</display-name>
  <welcome-file-list>
    <welcome-file>bienvenida.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
  </welcome-file-list>
  
  <!-- Declaración de roles de seguridad de la aplicación -->
  <security-role>
      <description>Rol para el alumnado</description>
      <role-name>rolalu</role-name>
  </security-role>
  
  <security-role>
      <description>Rol para el profesorado</description>
      <role-name>rolpro</role-name>
  </security-role>
  
  <!-- 1. Restricción para el Alumnado -->
  <security-constraint>
      <web-resource-collection>
          <web-resource-name>Area exclusiva de Alumnos</web-resource-name>
          <!-- Protegemos todas las URLs que empiecen por /alumno/ -->
          <url-pattern>/alumno/*</url-pattern>
      </web-resource-collection>
      <auth-constraint>
          <!-- Solo los usuarios con este rol pueden entrar -->
          <role-name>rolalu</role-name>
      </auth-constraint>
  </security-constraint>

  <!-- 2. Restricción para el Profesorado -->
  <security-constraint>
      <web-resource-collection>
          <web-resource-name>Area exclusiva de Profesores</web-resource-name>
          <!-- Protegemos todas las URLs que empiecen por /profesor/ -->
          <url-pattern>/profesor/*</url-pattern>
      </web-resource-collection>
      <auth-constraint>
          <!-- Solo los usuarios con este rol pueden entrar -->
          <role-name>rolpro</role-name>
      </auth-constraint>
  </security-constraint>

  <!-- Configuración del método de Login con Formulario HTML -->
  <login-config>
      <auth-method>FORM</auth-method>
      <realm-name>Area Protegida de Notas OnLine</realm-name>
      <form-login-config>
          <!-- Ruta a la página HTML de bienvenida -->
          <form-login-page>/bienvenida.html</form-login-page>
          <!-- Ruta a una página por si el usuario se equivoca de contraseña -->
          <form-error-page>/error-login.html</form-error-page>
      </form-login-config>
  </login-config>
  
<servlet>
      <servlet-name>LogoutServlet</servlet-name>
      <servlet-class>es.upv.dew.servlets.LogoutServlet</servlet-class>
  </servlet>
  
  <servlet-mapping>
      <servlet-name>LogoutServlet</servlet-name>
      <url-pattern>/logout</url-pattern>
  </servlet-mapping>
    
<filter>
      <filter-name>FiltroSeguridad</filter-name>
      <filter-class>es.upv.dew.filtros.FiltroSeguridad</filter-class>
  </filter>
  
  <filter-mapping>
      <filter-name>FiltroSeguridad</filter-name>
      <url-pattern>/*</url-pattern> 
  </filter-mapping>
  
</web-app>